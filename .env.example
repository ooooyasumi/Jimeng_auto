# ============================================
# 即梦视频队列 — 环境变量配置
# ============================================
# 直接复制为 .env 即可使用，无需修改任何配置
#   cp .env.example .env
# ============================================

# 登录密码 (默认 admin123，改成你自己的)
PASSWORD=admin123

# JWT 签名密钥 (默认值可用于本地开发，生产环境请改成随机字符串)
JWT_SECRET=jimeng-queue-secret-change-in-production

# 轮询间隔，单位秒 (默认 30)
POLL_INTERVAL=30

# ---- 腾讯云 COS 配置 (可选，不配置则无法上传参考文件) ----
# COS_SECRET_ID=your-cos-secret-id
# COS_SECRET_KEY=your-cos-secret-key
# COS_REGION=ap-guangzhou
# COS_CUSTOM_DOMAIN=your-bucket.cos.your-domain.com
